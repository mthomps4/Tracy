# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
tracy-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# ---- Tracy additions ----

# direnv — never commit actual dev env (.envrc.example is the template)
.envrc

# Docker / runtime env — never commit actual env (.env.example is the template)
.env

# Claude Code per-project: commit skills/agents/commands/hooks/settings.json,
# ignore only machine-local settings and transient state
.claude/settings.local.json
.claude/.session/
.claude/cache/
.claude/*.log

# SOPS-decrypted secrets (encrypted forms ARE safe to commit; decrypted are not)
*.dec
*.dec.yaml
*.dec.json
secrets/*.plain.*

# Editor swap files (vim/nvim)
*.swp
*.swo
*~

# macOS
.DS_Store

# Elixir LSP caches (ElixirLS / Lexical / Next-LS — keep IDE state out of git)
.elixir_ls/
.lexical/
.next_ls/

# Local-only IDE / editor configs (committed configs live in shared dotfiles)
/.vscode/
/.idea/

# Coverage / profiling output beyond /cover/
/excoveralls.json

# Per-plan worker workspaces — workers cd into these to read/write/organise
# artifacts (designer mockups, generated PNGs, scratch files). Override the
# root with `config :tracy, workspace_root: "/abs/path"` for prod hosts.
/workspaces/
