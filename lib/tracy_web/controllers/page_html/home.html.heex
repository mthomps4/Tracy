<Layouts.public flash={@flash} current_scope={@current_scope}>
  <%!-- Hero — single column on mobile, content-first --%>
  <section class="relative isolate overflow-hidden px-4 pt-12 pb-16 sm:px-6 sm:pt-20 sm:pb-24 lg:px-8 lg:pt-28 lg:pb-36">
    <%!-- accent web glow behind the headline --%>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 left-1/2 -z-10 size-[44rem] -translate-x-1/2 rounded-full bg-primary/15 blur-3xl sm:size-[56rem]"
    />

    <div class="mx-auto flex w-full max-w-3xl flex-col items-center text-center">
      <div class="mb-6 flex items-center justify-center text-primary">
        <img src={~p"/images/logo.svg"} alt="" class="size-16 sm:size-20" />
      </div>

      <p class="mb-3 inline-flex items-center gap-2 rounded-full border border-base-300/60 px-3 py-1 text-xs font-medium uppercase tracking-wider text-base-content/70">
        <span class="size-1.5 rounded-full bg-success web-pulse" /> Phase 0 · skeleton up
      </p>

      <h1 class="text-balance text-4xl font-bold tracking-tight text-base-content sm:text-5xl md:text-6xl">
        Your <span class="text-primary">boardroom</span>,<br class="hidden sm:block" />
        always at the desk.
      </h1>

      <p class="mt-6 max-w-xl text-pretty text-base leading-relaxed text-base-content/80 sm:text-lg">
        Tracy is a personal AI dev orchestrator. The C-Suite (you and Claude) plans and delegates;
        a roster of specialised workers gets the work done. Cross-project memory keeps the threads
        connected. Tracy on the go.
      </p>

      <div class="mt-10 flex w-full max-w-sm flex-col gap-3 sm:max-w-none sm:flex-row sm:justify-center">
        <%= if @current_scope do %>
          <.link navigate={~p"/boardroom"} class="btn btn-primary btn-lg w-full sm:w-auto">
            Enter the boardroom <.icon name="hero-arrow-right-mini" class="size-5" />
          </.link>
        <% else %>
          <.link navigate={~p"/users/register"} class="btn btn-primary btn-lg w-full sm:w-auto">
            Register
          </.link>
          <.link navigate={~p"/users/log-in"} class="btn btn-ghost btn-lg w-full border border-base-300 sm:w-auto">
            Log in
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Roster — mobile-stack to tablet-grid --%>
  <section class="border-t border-base-300/40 bg-base-200/40 px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
    <div class="mx-auto w-full max-w-6xl">
      <div class="mb-8 flex flex-col gap-2 sm:mb-12">
        <h2 class="text-2xl font-semibold tracking-tight text-base-content sm:text-3xl">
          The roster
        </h2>
        <p class="text-sm text-base-content/70 sm:text-base">
          Workers are role-based. Cheap models for routine, Sonnet for the work, Opus when it's hard.
        </p>
      </div>

      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <.roster_card icon="hero-cpu-chip" name="Engineer" model="Sonnet" desc="implement, test, propose PRs" />
        <.roster_card icon="hero-magnifying-glass" name="Researcher" model="Haiku" desc="web, books, docs digest" />
        <.roster_card icon="hero-clipboard-document-check" name="PM" model="Haiku" desc="triage, status, housekeeping" />
        <.roster_card icon="hero-eye" name="Reviewer" model="Sonnet" desc="critique, second opinion" />
        <.roster_card icon="hero-pencil-square" name="Note-taker" model="Haiku" desc="memory writes, recaps" />
        <.roster_card icon="hero-wrench-screwdriver" name="Operator" model="Sonnet" desc="deploys, ops, runbooks" />
        <.roster_card icon="hero-bell-alert" name="Scout" model="Haiku" desc="watches signals, persistent" />
        <.roster_card icon="hero-sparkles" name="…and more" model="config" desc="roster is YAML — add your own" />
      </ul>
    </div>
  </section>

  <%!-- Pillars — three columns at lg, stack on mobile/tablet --%>
  <section class="px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
    <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <.pillar
        icon="hero-square-3-stack-3d"
        title="One session for the world"
        body="Main Claude session = the boardroom. Persistent context across every project, shifts focus on command. Workers do the execution; the room does the thinking."
      />
      <.pillar
        icon="hero-archive-box"
        title="Memory that compounds"
        body="Episodes, facts, procedures — three-layer memory in Postgres + pgvector + Apache AGE. Nightly consolidation extracts what mattered. Years of context, queryable in milliseconds."
      />
      <.pillar
        icon="hero-bolt-slash"
        title="Day-job safe"
        body="Two budgets, color-bar meter, graceful wind-down at 75% with handoff notes for next week. Tracy never eats your real work."
      />
    </div>
  </section>
</Layouts.public>
